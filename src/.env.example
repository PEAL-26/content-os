# ===========================================
# DATABASE
# ===========================================

# Connection Pooling (para a app — usa pgBouncer)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?pgbouncer=true"

# Direct Connection (para migrações Prisma)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ===========================================
# SUPABASE
# ===========================================

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ===========================================
# AI PROVIDERS - Multi-Provider com Fallback
# ===========================================
# Ordem de prioridade: Anthropic > OpenAI > Google > Groq > DeepSeek > Cerebras > Together > OpenRouter > Ollama
# O sistema tenta automaticamente o próximo provider se um falhar (sem créditos, rate limit, timeout, etc.)
# Se todos falharem, faz retry após 3 segundos

# Tier 1 - Providers principais
# https://console.anthropic.com/ - Modelo: claude-sonnet-4-20250514
VITE_ANTHROPIC_API_KEY=

# https://platform.openai.com/api-keys - Modelos: gpt-4o, gpt-4o-mini
VITE_OPENAI_API_KEY=

# https://aistudio.google.com/app/apikey - Modelos: gemini-2.0-flash, gemini-1.5-flash
VITE_GEMINI_API_KEY=

# Tier 2 - Providers gratuitos/baratos
# https://console.groq.com/keys - Modelos: llama-3.3-70b-versatile (30 RPM gratuito)
VITE_GROQ_API_KEY=

# https://opencode.ai/workspace - Modelos: Big Pickle (1M tokens gratuito)
VITE_OPEN_CODE_ZEN_API_KEY=""
VITE_OPEN_CODE_ZEN_API_URL="https://opencode.ai/zen/v1/chat/completions"

# https://platform.deepseek.com/api_keys - Modelos: deepseek-chat ($0.14/1M tokens)
VITE_DEEPSEEK_API_KEY=

# https://cloud.cerebras.ai/ - Modelos: llama3.3-70b (1M tokens/grátis/mês)
VITE_CEREBRAS_API_KEY=

# https://api.together.ai/ - Modelos: meta-llama/Llama-3.3-70B-Instruct-Turbo (free tier)
VITE_TOGETHER_API_KEY=

# https://openrouter.ai/keys - Access to 300+ models
VITE_OPENROUTER_API_KEY=

# Tier 3 - Providers locais
# https://ollama.com/ - Modelos locais no teu computador
# VITE_OLLAMA_API_KEY=ollama
# VITE_OLLAMA_URL=http://localhost:11434

# Configuração
VITE_AI_PROVIDER_PRIORITY=anthropic,openai,google,groq,deepseek,cerebras,together
VITE_AI_DEFAULT_MODEL=gpt-4o-mini