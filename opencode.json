{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "auto",
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "instructions": ["README.md", "docs/guidelines.md"],
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
